    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "chai": "^4.4.1",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0"
  }
}
