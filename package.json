{
  "name": "shipdapp",
  "version": "0.1.0",
  "description": "pump.fun for apps — Deploy an app, launch a token, trading tax pays hosting",
  "private": true,
  "scripts": {
    "build:program": "anchor build",
    "test:program": "anchor test",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "dev:worker": "npm run dev --prefix cloudflare-backend",
