    "build:sdk": "npm run build --prefix sdk",
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix sdk && npm install --prefix cloudflare-backend"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@solana/spl-token": "^0.1.8",
