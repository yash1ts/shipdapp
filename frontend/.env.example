# After `anchor deploy`, set your devnet program id (must match Anchor.toml + lib.rs declare_id!)
NEXT_PUBLIC_SHIPDAPP_PROGRAM_ID=11111111111111111111111111111111

# Optional: own devnet RPC (Helius / QuickNode / Alchemy) — avoids public api.devnet.solana.com rate limits.
# Match the same URL in the Cloudflare Worker secret SOLANA_RPC_URL for the cron/workflow.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Launch page → Cloudflare Worker API (`/api/...`). Point at your deployed worker URL.
NEXT_PUBLIC_API_URL=https://cloudflare-backend.your-account.workers.dev

# Optional: on the Worker, set PUBLIC_FRONTEND_URL (wrangler.jsonc vars) to this same Pages / app
# URL so opening the workers.dev host in a browser redirects to the Next.js UI instead of the API landing page.
