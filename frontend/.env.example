# After `anchor deploy`, set your devnet program id (must match Anchor.toml + lib.rs declare_id!)
NEXT_PUBLIC_SHIPDAPP_PROGRAM_ID=11111111111111111111111111111111

# Optional: own devnet RPC (Helius / QuickNode / Alchemy) — avoids public api.devnet.solana.com rate limits.
# Match the same URL in Supabase Edge secret SOLANA_RPC_URL for the cron.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Launch → Supabase Edge (`functions/v1/...`). Requires `verify_jwt = false` on those functions (see `supabase/config.toml`).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
